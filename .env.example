VITE_ENGINE_VERSION=55a

# ── Sprint 71: SaaS Operator Layer ───────────────────────────────────────────
# Required for the notify-new-signup Edge Function.
# Configure these as secrets in Supabase Dashboard → Edge Functions → Secrets,
# NOT as .env files (secrets are injected at runtime by the Supabase platform).

# Shared secret between the Supabase database webhook and the notify-new-signup function.
# The webhook Authorization header must equal "Bearer <WEBHOOK_SECRET>".
WEBHOOK_SECRET=change-me-to-a-random-secret

# Email address to receive new-user signup notifications.
ADMIN_NOTIFY_EMAIL=admin@example.com

# Resend API key for sending transactional emails (https://resend.com).
RESEND_API_KEY=re_...

# Optional: Slack incoming webhook URL for parallel Slack notifications.
# If unset, Slack notifications are skipped silently.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
